# ================================================================
# UAV Path Planning System - Environment Configuration
# ================================================================
# 复制此文件为 .env 并根据你的环境进行修改
#   cp .env.example .env
#
# ⚠️  注意：此 .env 文件包含敏感信息，请不要提交到版本控制系统
#    Add .env to your .gitignore file
# ================================================================

# ─── Docker Hub 镜像配置 ─────────────────────────────────────────
# 镜像源选择：
#   - 本地构建：使用 docker-compose.yml 中的 build 段构建本地镜像
#   - Docker Hub：使用 dithiothreitollf 账户下的公开镜像（推荐团队使用）
#   - GitHub Container Registry：使用 ghcr.io 镜像
#
# 如果要使用 Docker Hub 镜像，需要在 docker-compose.yml 中
# 注释掉 build 段，只保留 image 行，示例：
#
#   api-gateway:
#     image: dithiothreitollf/api-gateway:latest
#     # build:
#     #   context: .
#     #   dockerfile: ./api-gateway/Dockerfile

# ─── Database ──────────────────────────────────────────────────
# 数据库密码（强烈建议修改为强密码，至少 16 字符）
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS
DB_ROOT_PASSWORD=${DB_PASSWORD}
DB_HOST=mysql
DB_PORT=3306

# ─── Redis ─────────────────────────────────────────────────────
# Redis 缓存配置
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT Authentication ────────────────────────────────────────
# JWT 密钥（用于生成和验证 JWT token）
# 建议使用强随机字符串，最少 256 位
JWT_SECRET=uav-platform-jwt-secret-must-be-256-bits-long-for-hs512
JWT_SECRET_KEY=${JWT_SECRET}
JWT_EXPIRATION=86400000

# ─── Nacos ─────────────────────────────────────────────────────
# Nacos 服务发现和配置中心
NACOS_SERVER=nacos:8848
NACOS_NAMESPACE=
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ─── Service Ports ─────────────────────────────────────────────
# 各服务端口配置（确保不与其他服务冲突）
API_GATEWAY_PORT=8088
UAV_PLATFORM_PORT=8080
WRF_PROCESSOR_PORT=8081
METEOR_FORECAST_PORT=8082
PATH_PLANNING_PORT=8083
DATA_ASSIMILATION_PORT=8084
FENGWU_SERVICE_PORT=8085
WEATHER_COLLECTOR_PORT=8086
EDGE_COORDINATOR_PORT=8000
EDGE_WS_PORT=8765
FRONTEND_PORT=3000

# ─── CORS ──────────────────────────────────────────────────────
# CORS 跨域允许的源（用逗号分隔多个源）
# 生产环境务必改为实际的前端地址
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Security ──────────────────────────────────────────────────
# 管理员密码（必须修改）
SECURITY_USER_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
# FengWu 服务 API Key（可选，用于生产环境）
FENGWU_API_KEY=
# JWT 颁发者和受众
JWT_ISSUER=uav-platform
JWT_AUDIENCE=uav-frontend

# ─── Logging ───────────────────────────────────────────────────
# 日志配置
LOG_PATH=/logs
LOG_LEVEL=INFO
ENVIRONMENT=production

# ─── Monitoring ────────────────────────────────────────────────
# Prometheus 和 Grafana 配置
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
PROMETHEUS_RETENTION=30d
ALERTMANAGER_WEBHOOK_URL=

# ─── Kafka ─────────────────────────────────────────────────────
# Kafka 消息队列配置
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PREFIX=uav

# ─── External Services ─────────────────────────────────────────
# 外部服务（可选）
NVD_API_KEY=
SENTRY_DSN=

# ─── JVM Options (Docker) ──────────────────────────────────────
# Java 虚拟机内存配置
JAVA_OPTS_SMALL=-Xms256m -Xmx512m
JAVA_OPTS_MEDIUM=-Xms512m -Xmx1g
JAVA_OPTS_LARGE=-Xms1g -Xmx2g

# ─── Python ────────────────────────────────────────────────────
# Python 环境配置
PYTHONUNBUFFERED=1
