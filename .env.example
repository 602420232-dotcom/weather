# UAV Path Planning System - Environment Configuration Template
# Copy this file to .env and fill in the values

# ===== Environment =====
ENVIRONMENT=development

# ===== Security Configuration =====
# JWT Secret Key (minimum 32 characters recommended)
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=your-jwt-secret-key-here-min-32-chars

# Encryption Key for AES-256-GCM (minimum 32 characters recommended)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-encryption-key-here-min-32-chars

# ===== Database Configuration =====
DB_PASSWORD=your-secure-database-password

# ===== CORS Configuration =====
# Comma-separated list of allowed origins
# For development: http://localhost:3000,http://localhost:8080
# For production: https://yourdomain.com,https://api.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===== Service URLs =====
SERVICES_WRF_PROCESSOR_URL=http://wrf-processor:8081/api/wrf
SERVICES_DATA_ASSIMILATION_URL=http://data-assimilation:8084/api/assimilation
SERVICES_METEOR_FORECAST_URL=http://meteor-forecast:8082/api/forecast
SERVICES_PATH_PLANNING_URL=http://path-planning:8083/api/planning

# ===== Redis Configuration =====
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# ===== Nacos Configuration =====
NACOS_SERVER=nacos:8848

# ===== Python Configuration =====
UAV_PYTHON_SCRIPT_PATH=/app/python
UAV_PYTHON_TIMEOUT=30000

# ===== Logging Configuration =====
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===== Monitoring Configuration =====
ENABLE_METRICS=true
ENABLE_TRACING=true

# ===== Security Headers =====
ENABLE_SECURITY_HEADERS=true
CONTENT_SECURITY_POLICY=default-src 'self'
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# ===== Rate Limiting =====
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_ENABLED=true

# ===== Feature Flags =====
ENABLE_SWAGGER_UI=true
ENABLE_ACTUATOR_ENDPOINTS=true
