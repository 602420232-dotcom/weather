[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude = .git, __pycache__, build, dist, .venv, venv, node_modules

per-file-ignores =
    # Auto-generated test files: suppress issues inherent to skeleton test generation
    **/test_*.py: F403, F405, F811, F401, E402, E302, E303, E305, E306, E301, E128, E127, E231, E261, F541, E701, F821, E731, F841, E501, E999

    # Examples: demo/illustration code
    **/examples/*.py: F401, E501, E402, E128, E127, E231, E261, E303, F841, E301, E302, E305, E306

    # __init__.py: re-export imports, long import chains
    **/__init__.py: F401, E501, F811

    # Scripts and utilities: quick scripts, code generators, one-off tools
    **/scripts/*.py: F401, E501, E402, E128, E127, E301, E302, E305, E261, E231, F841

    # Fix/refactor helper scripts
    **_fix*.py: F401, E501, E402, E128, E127, E301, E302, E305

    # Flutter ephemeral generated code
    mobile/**/*.py: F401, E501, E402, E128, E127, E301, E302, E305, E261, E231, F841, F401, F541

    # Jupyter notebook exports and docs scripts
    **/notebooks/*.py: F401, E501, E402, E128, E127, E301, E302, E305, E261, E231, F841
