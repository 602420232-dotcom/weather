{
  "properties": [
    {
      "name": "jwt.secret",
      "type": "java.lang.String",
      "description": "JWT签名密钥（至少32字符），可通过环境变量 JWT_SECRET 配置"
    },
    {
      "name": "jwt.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "是否启用JWT认证。生产环境必须为true"
    },
    {
      "name": "jwt.expiration",
      "type": "java.lang.Long",
      "defaultValue": 86400000,
      "description": "JWT令牌过期时间（毫秒），默认24小时"
    },
    {
      "name": "jwt.key-rotation.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "是否启用JWT密钥轮换"
    },
    {
      "name": "jwt.key-store.path",
      "type": "java.lang.String",
      "description": "JWT密钥库文件路径"
    },
    {
      "name": "jwt.key-store.password",
      "type": "java.lang.String",
      "description": "JWT密钥库密码"
    },
    {
      "name": "jwt.key.alias",
      "type": "java.lang.String",
      "defaultValue": "jwt-signing-key",
      "description": "JWT签名密钥别名"
    }
  ]
}
