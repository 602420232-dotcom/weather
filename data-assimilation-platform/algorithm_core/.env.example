# 统一环境变量配置示例
# 复制此文件为 .env 并按需修改

# ===== JWT认证 =====
JWT_SECRET=
JWT_ENABLED=true

# ===== 数据库 =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=uav_path_planning
DB_USER=root
DB_PASSWORD=

# ===== Redis缓存 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== SSL/TLS =====
SSL_ENABLED=false
SSL_KEY_STORE=
SSL_KEY_STORE_PASSWORD=
SSL_KEY_ALIAS=

# ===== 算法路径 =====
PYTHONPATH=${PYTHONPATH}:./algorithm_core/src
ASSIMILATION_STRATEGY=hybrid
GPU_ENABLED=True
LOG_LEVEL=INFO
