{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AssimilationResponse",
  "description": "贝叶斯同化响应的 JSON Schema",
  "type": "object",
  "required": ["status"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error", "pending"],
      "description": "处理状态"
    },
    "analysis": {
      "type": "object",
      "properties": {
        "shape": { "type": "array", "items": { "type": "integer" } },
        "values": { "type": "array" }
      }
    },
    "variance": {
      "type": "object",
      "properties": {
        "shape": { "type": "array", "items": { "type": "integer" } },
        "values": { "type": "array" }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "iterations": { "type": "integer" },
        "final_cost": { "type": "number" },
        "reduction_rate": { "type": "number" },
        "elapsed_seconds": { "type": "number" }
      }
    },
    "message": { "type": "string" }
  }
}
