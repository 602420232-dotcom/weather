# Docker Compose JVM 参数统一配置文件
# 提供多种配置方案：SMALL、MEDIUM、LARGE
# 同时包含通用优化参数

# 通用 JVM 优化配置（所有服务共享）
JAVA_OPTS_COMMON=-XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+UseStringDeduplication -XX:+ParallelRefProcEnabled -Djava.security.egd=file:/dev/./urandom

# 小配置方案 - 轻量级服务（如 API Gateway、Weather Collector）
JAVA_OPTS_SMALL=-Xms256m -Xmx512m ${JAVA_OPTS_COMMON}

# 中配置方案 - 中等规模服务（如 WRF Processor、Meteor Forecast、Path Planning、UAV Platform）
JAVA_OPTS_MEDIUM=-Xms512m -Xmx1g ${JAVA_OPTS_COMMON}

# 大配置方案 - 计算密集型服务（如 Data Assimilation）
JAVA_OPTS_LARGE=-Xms1g -Xmx2g ${JAVA_OPTS_COMMON}

# 路径规划专属配置（更低的 GC 暂停时间）
JAVA_OPTS_PATH_PLANNING=-Xms512m -Xmx1g -XX:+UseG1GC -XX:MaxGCPauseMillis=100 -XX:+UseStringDeduplication -XX:+ParallelRefProcEnabled -Djava.security.egd=file:/dev/./urandom

# Data Assimilation 专属配置
JAVA_OPTS_DATA_ASSIMILATION=-Xms512m -Xmx1g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+ParallelRefProcEnabled -Djava.security.egd=file:/dev/./urandom
