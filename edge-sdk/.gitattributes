# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text diff=python

# C++ files
*.cpp text diff=cpp
*.h text diff=cpp
*.hpp text diff=cpp

# CMake files
CMakeLists.txt text
*.cmake text

# Documentation
*.md text
*.txt text

# Scripts
*.sh text eol=lf
*.bat text eol=crlf

# Binary files
*.pyd binary
*.so binary
*.dll binary
*.dylib binary
*.a binary

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Data files
*.npy binary
*.npz binary
*.h5 binary
*.hdf5 binary
*.nc binary

# Compressed files
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

# Logs
*.log binary

# Environment files
*.env text
.env text
