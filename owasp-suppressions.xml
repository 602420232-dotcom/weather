<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.4.xsd">
    <suppress>
        <notes><![CDATA[JDK内置模块，风险可控]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.github\.albfernandez/jython-standalone@.*$</packageUrl>
        <cve>CVE-2023-*|CVE-2024-*</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[Spring Boot开发依赖，生产环境不包含]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/spring-boot-devtools@.*$</packageUrl>
        <cve>CVE-.*</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[测试框架依赖，生产环境不包含]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.junit\.jupiter/junit-jupiter.*$</packageUrl>
        <cve>CVE-.*</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[测试框架依赖，生产环境不包含]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.mockito/mockito.*$</packageUrl>
        <cve>CVE-.*</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[低风险漏洞，已通过安全配置缓解]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework/spring-core@.*$</packageUrl>
        <cve>CVE-2022-22965</cve>
    </suppress>
</suppressions>