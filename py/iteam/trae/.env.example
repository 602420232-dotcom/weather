# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=uav_path_planning
DB_USER=root
DB_PASSWORD=your-database-password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 服务器配置
SERVER_PORT=8080
SSL_ENABLED=false
SSL_KEY_STORE=
SSL_KEY_STORE_PASSWORD=
SSL_KEY_ALIAS=

# JWT配置
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRATION=86400000

# gRPC配置
GRPC_HOST=localhost
GRPC_PORT=50051

# 服务配置
WRF_PROCESSOR_PORT=8081
METEOR_FORECAST_PORT=8082
PATH_PLANNING_PORT=8083
DATA_ASSIMILATION_PORT=8084

# 环境配置
SPRING_PROFILES_ACTIVE=prod

# 资源配置
JAVA_OPTS=-Xms2G -Xmx4G

# 日志配置
LOG_LEVEL=info