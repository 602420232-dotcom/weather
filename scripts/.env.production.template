# ==========================================
# Production Environment Template
# ==========================================
# ⚠️  THIS IS A TEMPLATE ONLY
# ⚠️  DO NOT FILL IN REAL VALUES HERE
# ⚠️  Use Vault / AWS Secrets Manager / Azure Key Vault
# ⚠️  CI/CD injects these at deploy time
# ==========================================

# Environment
ENVIRONMENT=production

# ─── JWT ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Must be rotated every 90 days
JWT_SECRET=__FILL_IN_VAULT__

# ─── Database ─────────────────────────────────────────────
DB_HOST=__FILL_IN_VAULT__
DB_PORT=3306
DB_USER=__FILL_IN_VAULT__
DB_PASSWORD=__FILL_IN_VAULT__

# ─── CORS ─────────────────────────────────────────────────
# Production domain(s) only - no localhost, no wildcards
CORS_ORIGINS=https://app.uav-platform.com

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=__FILL_IN_VAULT__
REDIS_PORT=6379
REDIS_PASSWORD=__FILL_IN_VAULT__

# ─── Service URLs ─────────────────────────────────────────
SERVICES_WRF_PROCESSOR_URL=http://wrf-processor:8081
SERVICES_DATA_ASSIMILATION_URL=http://data-assimilation:8084
SERVICES_METEOR_FORECAST_URL=http://meteor-forecast:8082
SERVICES_PATH_PLANNING_URL=http://path-planning:8083

# ─── JPA ──────────────────────────────────────────────────
# NEVER use 'update' in production
JPA_DDL_AUTO=validate

# ─── Management ───────────────────────────────────────────
# Use separate port for actuator endpoints
MANAGEMENT_SERVER_PORT=8089
# Do not expose health check details
MANAGEMENT_HEALTH_DETAILS=never

# ─── SSL ──────────────────────────────────────────────────
SSL_ENABLED=true
SSL_KEY_STORE=__FILL_IN_VAULT__
SSL_KEY_STORE_PASSWORD=__FILL_IN_VAULT__
SSL_KEY_ALIAS=uav-platform

# ─── Security ─────────────────────────────────────────────
# FengWu API Key (rotate every 30 days)
FENGWU_API_KEY=__FILL_IN_VAULT__
FENGWU_ENV=production

# Encryption key for sensitive data (rotate every 90 days)
ENCRYPTION_KEY=__FILL_IN_VAULT__

# ─── Cesium ──────────────────────────────────────────────
VITE_CESIUM_ION_TOKEN=__FILL_IN_VAULT__

# ─── Monitoring ──────────────────────────────────────────
ENABLE_METRICS=true
ENABLE_TRACING=true
LOG_LEVEL=WARN

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_ENABLED=true

# ─── MySQL Root ──────────────────────────────────────────
MYSQL_ROOT_PASSWORD=__FILL_IN_VAULT__

# ─── Weather API ─────────────────────────────────────────
WEATHER_API_KEY=__FILL_IN_VAULT__

# ─── Feature Flags (production) ──────────────────────────
ENABLE_SWAGGER_UI=false
ENABLE_ACTUATOR_ENDPOINTS=true
